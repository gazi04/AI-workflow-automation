# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/workflow_automation

# For Docker Compose environment (when running inside containers)
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/workflow_automation

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# JWT Configuration 
JWT_SECRET_KEY=your-secret-key-here

# Fernet key for encrypting OAuth tokens at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Auth cookie configuration. Defaults suit local dev (same-site localhost).
# Production cross-domain: COOKIE_SECURE=true and COOKIE_SAMESITE=none.
FRONTEND_URL=http://localhost:5173
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# CORS Configuration
CORS_ORIGINS=http://localhost:5173

# Google OAuth Configuration
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
GOOGLE_CLOUD_EMAIL_TOPIC=

# Pub/Sub push OIDC verification for POST /api/webhooks/gmail.
# GOOGLE_PUBSUB_AUDIENCE is the public push-endpoint URL Google signs its OIDC
# token for (e.g. https://api.yourdomain.com/api/webhooks/gmail).
# SECURITY: with REQUIRE_PUBSUB_OIDC=true (the default), leaving the audience
# unset makes the webhook FAIL CLOSED (503) instead of accepting unverified
# requests. Set REQUIRE_PUBSUB_OIDC=false ONLY for local dev.
GOOGLE_PUBSUB_AUDIENCE=
REQUIRE_PUBSUB_OIDC=true

# Azure AI Configuration 
AZURE_ENDPOINT=
AZURE_MODEL=
AZURE_API_KEY=

ALGORITHM="HS256"

